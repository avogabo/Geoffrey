# PicoClaw-facing minimal Geoffrey configuration

# Telegram
TELEGRAM_BOT_TOKEN=

# LLM provider
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Plex
